{
    "type": "package",
    "name": "quietgarden/elm-web3-ui",
    "summary": "UI primitives for elm-web3: wallet, transaction, address, and input components.",
    "license": "MIT",
    "version": "1.0.0",
    "exposed-modules": [
        "Web3.Ui.Wallet",
        "Web3.Ui.Transaction",
        "Web3.Ui.Address",
        "Web3.Ui.Balance",
        "Web3.Ui.Input",
        "Web3.Ui.Sign"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.5 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
"quietgarden/elm-web3": "2.0.0 <= v < 3.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.2.1 <= v < 3.0.0"
    }
}
